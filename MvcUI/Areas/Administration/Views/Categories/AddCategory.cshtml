@using Microsoft.AspNetCore.Mvc.TagHelpers
@model BusinessLayer.Models.Categories.CategoryInputModel
@{
    ViewData["Title"] = "Add Category";
}

<div class="row">
    <div class="col-md-4">
        <form method="post" enctype="multipart/form-data">
            <div class="form-group">
                <label class="control-label">Kategori Adı</label>
                <div class="col-sm-10">
                    <input type="text" asp-for="@Model.Name" class="form-control" required="required">
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
            </div>
            <div class="form-group">
                <label class="control-label">Resim</label>
                <input type="file" name="Image" />
            </div>
            <div class="form-group">
                <label class="control-label">Açıklama</label>
                <div class="col-sm-10">
                    <textarea type="text" asp-for="@Model.Description" class="form-control" required="required"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
            </div>
            <div class="form-group">
                <div class="col-sm-6 text-right">
                    <button type="submit" class="btn btn-success"
                            asp-area="Administration" asp-controller="Categories" asp-action="AddCategory">
                        Ekle
                    </button>
                </div>
                <div class="col-sm-6">
                    <button type="submit" class="btn btn-danger"
                            asp-area="Administration" asp-controller="Categories" asp-action="Index">
                        İptal
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>


