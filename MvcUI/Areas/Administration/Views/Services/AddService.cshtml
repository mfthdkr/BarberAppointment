@model BusinessLayer.Models.Services.ServiceInputModel

@{
    ViewData["Title"] = "AddService";
    Layout = "~/Areas/Administration/Views/Shared/_AdminLayout.cshtml";
    var categories = ViewData["Categories"] as SelectList;
}

<p>Hizmet ekleme sayfası</p>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="AddService" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Name" class="control-label">İsim</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label class="col-sm-2 col-form-label">Kategori</label>
                <div class="col-sm-10">
                    <select asp-for="@Model.CategoryId" class="form-control" asp-items="@categories">
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>
            </div>
            <div class="form-group">
                <label class="col-sm-2 col-form-label">Açıklama</label>
                <div class="col-sm-10">
                    <textarea type="text" asp-for="@Model.Description" class="form-control" required="required"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
            </div>
            <div class="form-group">
                <div class="form-group row">
                    <div class="col-sm-6 text-right">
                        <button type="submit" class="btn btn-success"
                                asp-area="Administration" asp-controller="Services" asp-action="AddService">
                            Ekle.
                        </button>
                    </div>
                    <div class="col-sm-6">
                        <a class="btn btn-danger" asp-area="Administration" asp-controller="Services" asp-action="Index">İptal</a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>



@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    }
