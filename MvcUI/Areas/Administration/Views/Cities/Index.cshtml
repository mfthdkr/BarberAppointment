
@using Microsoft.AspNetCore.Mvc.TagHelpers
@model BusinessLayer.Models.Cities.CitiesListViewModel
@{
    ViewData["Title"] = "Cities";
}

<h2>
    Bütün şehirler (@Model.Cities.Count())
    <span>
        <a class="btn btn-info" asp-area="Administration" asp-controller="Cities" asp-action="AddCity">Yeni şehir ekle</a>
    </span>
</h2>

<table class="table table-bordered table-striped">
    <thead class="thead-light">
        <tr>
            <th scope="col">Şehir</th>
            <th scope="col">Kuaför sayısı</th>
            <th scope="col">Sil</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var city in Model.Cities)
        {
            <tr>
                <th scope="row">@city.Name</th>
                <td>@city.SalonsCount</td>
                <td>
                    @if (city.Id <= 2)
                    {
                        <div class="text-muted" style="font-size:smaller">
                            örnek veri silinemez.
                        </div>
                    }
                    else
                    {
                        <form method="post">
                            <button type="submit" class="btn btn-danger btn-sm"
                                    asp-area="Administration" asp-controller="Cities" asp-action="DeleteCity" asp-route-id="@city.Id">
                                Sil
                            </button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
