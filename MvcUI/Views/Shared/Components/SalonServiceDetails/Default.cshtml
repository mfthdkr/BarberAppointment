@model BusinessLayer.Models.SalonServices.SalonServiceDetailsViewModel
@{
    ViewData["Title"] = "Default";
}

<div class="form-group row">
    <label class="col-sm-2 col-form-label">Kuaför</label>
    <div class="col-sm-10">
        <div class="form-control">@Model.SalonName</div>
    </div>
</div>
<div class="form-group row">
    <label class="col-sm-2 col-form-label">Adres</label>
    <div class="col-sm-10">
        <div class="form-control">@Model.SalonCityName, @Model.SalonAddress</div>
    </div>
</div>
<div class="form-group row">
    <label class="col-sm-2 col-form-label">Hizmet</label>
    <div class="col-sm-10">
        <div class="form-control">@Model.ServiceName</div>
    </div>
</div>
