@using Microsoft.AspNetCore.Mvc.TagHelpers
@model BusinessLayer.Models.Categories.CategoriesSimpleListViewModel
@{
    ViewData["Title"] = "Default";
}

<div class="btn-group dropright ml-5">
    <button type="button" style="" class="btn btn-secondary btn-lg dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
        Kategori seç.
    </button>
    <div class="dropdown-menu">
        @foreach (var category in Model.Categories)
        {
            <a class="dropdown-item" 
               asp-area="" asp-controller="Salons" asp-action="Index" asp-route-sortId="@category.Id">
                @category.Name (@category.SalonsCount)
            </a>
        }
        <div class="dropdown-divider"></div>
        <a class="dropdown-item" asp-area="" asp-controller="Salons" asp-action="Index">Bütün kuaförler.</a>
    </div>
</div>


